#!/usr/bin/env bash
# Global pre-commit hook: runs repo-local linters first, then code review.
# Skip with: git commit --no-verify

set -euo pipefail

# Guard: prevent infinite recursion if .git/hooks/pre-commit forwards here
[ "${_CLAUDE_HOOK_RUNNING:-}" = "1" ] && exit 0
export _CLAUDE_HOOK_RUNNING=1

# --- Step 1: Run repo-local pre-commit hook (linters: ruff, pylint, xmllint) ---
# core.hooksPath overrides .git/hooks/, so we call the local one explicitly.
# In worktrees, git-dir points to .git/worktrees/<name> which has no hooks/.
# Use git-common-dir to find the shared hooks directory.
COMMON_DIR="$(git rev-parse --git-common-dir 2>/dev/null)"
LOCAL_HOOK="$COMMON_DIR/hooks/pre-commit"
if [ -f "$LOCAL_HOOK" ] && [ -x "$LOCAL_HOOK" ]; then
    "$LOCAL_HOOK"
fi

# --- Step 2: Export commit message draft for the reviewer ---
# git writes COMMIT_EDITMSG into the WORKTREE-specific git-dir (not
# git-common-dir) before pre-commit for both `-m` and editor flows.
# The mtime check (≤10s) avoids leaking a stale message from the
# previous commit.
GIT_DIR="$(git rev-parse --git-dir 2>/dev/null)"
COMMIT_MSG_FILE="$GIT_DIR/COMMIT_EDITMSG"
if [ -f "$COMMIT_MSG_FILE" ]; then
    # review-note: mtime freshness gate — the message file persists on disk
    # after the previous commit, so without this guard we would leak stale
    # content into CLAUDE_COMMIT_MSG. 0.17 min ≈ 10s covers the git write
    # that happens immediately before pre-commit runs.
    if [ "$(find "$COMMIT_MSG_FILE" -mmin -0.17 2>/dev/null)" ]; then
        # review-note: shell plumbing below the Python-tested CLAUDE_COMMIT_MSG
        # contract (see review/test_hook.py::test_build_user_prompt_includes_commit_message_*).
        # Strip git's helper comments (#) and blank lines before export.
        CLAUDE_COMMIT_MSG="$(grep -v '^#' "$COMMIT_MSG_FILE" | sed '/^$/d' || true)"
        export CLAUDE_COMMIT_MSG
    fi
fi

# --- Step 3: Run code review (on already-linted code) ---
REVIEW_SCRIPT="$HOME/.claude/review/hook.py"
if [ -f "$REVIEW_SCRIPT" ]; then
    python3 -B "$REVIEW_SCRIPT"
fi
