{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "statusLine": {
    "type": "command",
    "command": "bash /home/kern/.claude/statusline-command.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/kern/.claude/hooks/pre_commit_review.py",
            "timeout": 330
          }
        ]
      }
    ]
  }
}